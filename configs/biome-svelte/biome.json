{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@canonical/biome-config"],
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "overrides": [
    {
      "includes": ["**/*.svelte"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      },
      "html": {
        "formatter": {
          "indentScriptAndStyle": true
        }
      }
    }
  ]
}
