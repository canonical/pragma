{
  "name": "@canonical/lit-demo",
  "private": true,
  "version": "0.26.0",
  "type": "module",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "vite build --ssr src/ssr/server.ts --outDir dist/server",
    "serve": "bun run build:client && bun run build:server && node dist/server/server.js",
    "check": "bun run check:biome && bun run check:ts",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit"
  },
  "dependencies": {
    "@canonical/lit-ds-prototype": "^0.26.0",
    "@canonical/styles": "^0.26.0",
    "@canonical/styles-old": "^0.26.0",
    "@lit-labs/ssr": "^3.3.0",
    "@lit-labs/ssr-client": "^1.1.7",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@canonical/biome-config": "^0.26.0",
    "@canonical/typescript-config-lit": "^0.26.0",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "express": "^5.2.1",
    "@types/express": "^5.0.6",
    "vite": "^8.0.1"
  }
}
