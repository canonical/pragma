{
  "name": "@canonical/ke",
  "description": "Headless triple store runtime built on Oxigraph WASM",
  "version": "0.18.0",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./testing": {
      "types": "./testing/index.ts",
      "import": "./testing/index.ts"
    }
  },
  "files": [
    "src",
    "testing"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "scripts": {
    "build": "echo 'No build needed - runs directly from TypeScript'",
    "check": "bun run check:biome && bun run check:ts",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@canonical/biome-config": "^0.18.0",
    "@canonical/typescript-config": "^0.18.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "expect-type": "^1.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "oxigraph": "^0.4.8"
  }
}
