{
  "extends": "@canonical/typescript-config",
  "compilerOptions": {
    "baseUrl": "src",
    "types": ["node", "@types/bun"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "customConditions": ["development"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "demo/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "test/**/*.test.ts"]
}
