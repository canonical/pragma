{
  "name": "@canonical/summon",
  "description": "Summon CLI binary: interactive code generator with Ink UI, shell completion, and Commander registration.",
  "version": "0.19.0",
  "type": "module",
  "module": "src/bin.tsx",
  "bin": {
    "summon": "src/bin.tsx"
  },
  "files": [
    "src",
    "generators"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "scripts": {
    "build": "echo 'No build needed - runs directly from TypeScript'",
    "build:all": "bun run build",
    "check": "bun run check:biome && bun run check:ts",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@canonical/cli-core": "^0.19.0",
    "@canonical/summon-core": "^0.19.0",
    "@canonical/task": "^0.19.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "omelette": "^0.4.17",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@canonical/biome-config": "^0.19.0",
    "@canonical/typescript-config": "^0.19.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "@types/omelette": "^0.4.5",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
