{
  "name": "@canonical/pragma",
  "description": "CLI and MCP server for Canonical's design system.",
  "version": "0.18.0",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "pragma": "src/bin.ts"
  },
  "files": [
    "src"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "scripts": {
    "build": "echo 'No build needed - runs directly from TypeScript'",
    "build:compile": "bun build --compile --minify src/bin.ts --outfile dist/pragma",
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:webarchitect": "webarchitect tool-ts",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:compile": "bun run src/compile-validation.runner.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@canonical/biome-config": "^0.18.0",
    "@canonical/typescript-config": "^0.18.0",
    "@canonical/webarchitect": "^0.18.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@canonical/ke": "workspace:*",
    "chalk": "^5.6.2",
    "cli-framework": "workspace:*",
    "commander": "^14.0.3",
    "smol-toml": "^1.3.1"
  }
}
