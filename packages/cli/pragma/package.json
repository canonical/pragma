{
  "name": "@canonical/pragma-cli",
  "description": "CLI and MCP server for Canonical's design system.",
  "version": "0.24.0",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "pragma": "dist/pragma"
  },
  "files": [
    "src",
    "dist"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "os": [
    "linux"
  ],
  "cpu": [
    "x64"
  ],
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "imports": {
    "#config": "./src/config/index.ts",
    "#constants": "./src/constants.ts",
    "#error": "./src/error/index.ts",
    "#package-manager": "./src/package-manager/index.ts",
    "#pipeline": "./src/pipeline/index.ts",
    "#testing": "./src/testing/index.ts",
    "#tui": "./src/tui/index.ts"
  },
  "scripts": {
    "build": "bun build --compile --minify --target=bun-linux-x64 src/bin.ts --outfile dist/pragma",
    "build:compile": "bun build --compile --minify --target=bun-linux-x64 src/bin.ts --outfile dist/pragma",
    "prepublishOnly": "bun run build",
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:webarchitect": "webarchitect tool-ts",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:compile": "bun run src/compile-validation.runner.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^0.24.0",
    "@canonical/typescript-config": "^0.24.0",
    "@canonical/webarchitect": "^0.24.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "expect-type": "^1.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@canonical/anatomy-dsl": "^0.2.2",
    "@canonical/code-standards": "^0.1.2",
    "@canonical/design-system": "^0.1.2"
  },
  "dependencies": {
    "@canonical/cli-core": "^0.24.0",
    "@canonical/harnesses": "^0.24.0",
    "@canonical/ke": "^0.24.0",
    "@canonical/summon-component": "^0.24.0",
    "@canonical/summon-core": "^0.24.0",
    "@canonical/summon-package": "^0.24.0",
    "@canonical/task": "^0.24.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "oxigraph": "^0.5.0",
    "react": "^19.2.4",
    "zod": "^3.25.0"
  }
}
