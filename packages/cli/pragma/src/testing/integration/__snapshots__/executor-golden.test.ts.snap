  // Define props specific to Button here
}

\`\`\`

### src/components/Button/Button.tests.ts

\`\`\`ts
import { afterEach, beforeEach, describe, expect, it } from "vitest";
import "./Button.js";
import type Button from "./Button.js";

describe("Button component", () => {
  let elem: Button;

  beforeEach(() => {
    elem = document.createElement("ds-button") as Button;
    document.body.appendChild(elem);
  });

  afterEach(() => {
    elem.remove();
  });

  it("should render component", async () => {
    await customElements.whenDefined("ds-button");

    const container = elem.shadowRoot?.querySelector(".ds.button");
    expect(container).toBeTruthy();
  });

  it("should have correct tag name", () => {
    expect(elem.tagName.toLowerCase()).toBe("ds-button");
  });
});

\`\`\`

### src/components/Button/Button.stories.ts

\`\`\`ts
import type { Meta, StoryObj } from "@storybook/web-components-vite";
import { html } from "lit";

import "./Button.js";
import type Button from "./Button.js";

const meta = {
  title: "Web Components/Button",
  tags: ["autodocs"],
} satisfies Meta<Button>;

export default meta;
type Story = StoryObj<Button>;

export const Default: Story = {
  render: () => html\`<ds-button>Hello, Button!</ds-button>\`,
};

\`\`\`

### src/components/Button/styles.css

\`\`\`css
/*
 * Lit Layout Primer
 * Delete this comment block when you're done implementing.
 *
 * Styles live in a shadow DOM, isolated from the page by default.
 *
 * Two layers:
 *
 *   1) :host — the outer shell, how this component presents to its parent layout.
 *      display, width, height                          (always apply)
 *      grid-column, grid-row, align-self, justify-self (parent must be grid/flex)
 *
 *   2) .ds.button — the inner shell, how this component arranges its shadow children.
 *      display: grid/flex, gap, grid-template-columns, align-items, justify-content
 *
 * Subgrid pattern — use when the parent defines grid tracks you want to inherit:
 *
 *   In the parent component:
 *   .ds.parent { display: grid; grid-template-columns: repeat(4, 1fr); }
 *
 *   In this component:
 *   :host                { display: grid; grid-column: span 2; }
 *   .ds.button { display: grid; grid-template-columns: subgrid; }
 *
 *   In this example, the parent establishes a 4-column grid.
 *   This component claims 2 of those columns and inherits their widths via subgrid.
 *
 * Keep in mind:
 *   - Custom elements are display: inline by default — always set display on :host.
 *   - Flex/grid rules only affect direct children of the container, not deeper descendants.
 *   - External CSS cannot pierce the shadow boundary — expose CSS custom properties for theming.
 */

:host {
  /*
   * Host controls the outer layout role.
   * Declare component CSS variables here when needed.
   * Variables must be on :host to be accessible inside the shadow tree.
   *
   * Example:
   * --button-color-background: var(--color-background-default);
   * --button-color-text: var(--color-text-default);
   */
  display: inline-flex;
}

.ds.button {
  /* Inner layout and visual styles go here. */
}

