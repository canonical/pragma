\`\`\`ts
export { default as Button } from "./Button.js";
export type * from "./types.js";

\`\`\`

### src/components/Button/Button.tests.tsx

\`\`\`tsx
import { describe, expect, it } from "vitest";
import { render, screen } from "@testing-library/react";
import Button from "./Button.js";

describe("Button", () => {
	it("renders children", () => {
		render(<Button>Test content</Button>);
		expect(screen.getByText("Test content")).toBeInTheDocument();
	});

	it("applies custom className", () => {
		render(<Button className="custom-class">Content</Button>);
		const element = screen.getByText("Content");
		expect(element.className).toContain("ds button");
		expect(element.className).toContain("custom-class");
	});

	it("passes through additional props", () => {
		render(<Button data-testid="test-component">Content</Button>);
		expect(screen.getByTestId("test-component")).toBeInTheDocument();
	});
});

\`\`\`

### src/components/Button/Button.ssr.tests.tsx

\`\`\`tsx
import { describe, expect, it } from "vitest";
import { renderToString } from "react-dom/server";
import Button from "./Button.js";

describe("Button SSR", () => {
	it("renders without hydration errors", () => {
		const html = renderToString(<Button>Test content</Button>);
		expect(html).toContain("Test content");
		expect(html).toContain("ds button");
	});
});

\`\`\`

