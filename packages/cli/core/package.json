{
  "name": "@canonical/cli-core",
  "description": "Shared CLI machinery: CommandDefinition, registerAll, completions, OutputAdapter.",
  "version": "0.26.0",
  "type": "module",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:all": "bun run build",
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:webarchitect": "webarchitect library",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
    "test": "bun run test:vitest",
    "test:vitest": "vitest run --coverage",
    "test:vitest:watch": "vitest"
  },
  "dependencies": {
    "@canonical/summon-core": "^0.26.0",
    "@canonical/task": "^0.26.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^0.26.0",
    "@canonical/typescript-config": "^0.26.0",
    "@canonical/webarchitect": "^0.26.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
