exports[`emitScripts — snapshots (fixture model) > renders the bash script 1`] = `
"# pragma bash completion (static tier) — generated by \`pragma setup completions\`. Do not edit.
# Structure (nouns, verbs, flags, enum values) is inlined and never execs;
# entity arguments call \`pragma __complete\` (storeless, never-throw);
# file arguments use native completion. Requires bash >= 4 (mapfile).
_pragma_dynamic() {
  [ \${#cur} -ge 2 ] || return 0
  mapfile -t COMPREPLY < <("pragma" __complete -- "\${COMP_WORDS[@]:1:COMP_CWORD-1}" "$cur" 2>/dev/null)
}
_pragma_pos() {
  local skip="$1" vflags=" $2 " i w
  POS=0
  for ((i = 1; i < COMP_CWORD; i++)); do
    w="\${COMP_WORDS[i]}"
    case "$w" in
      -*) case "$vflags" in *" $w "*) ((i++)) ;; esac ;;
      *) if [ "$skip" -gt 0 ]; then skip=$((skip - 1)); else POS=$((POS + 1)); fi ;;
    esac
  done
}
_pragma() {
  local cur prev noun verb i w POS
  cur="\${COMP_WORDS[COMP_CWORD]}"
  prev="\${COMP_WORDS[COMP_CWORD-1]}"
  # Normalize the COMP_WORDBREAKS '=' split so a --flag=value context routes
  # as a flag value (mirrors parse.ts). The default breaks split
  # \`--flag=val\` into \`--flag\` \`=\` \`val\`; a custom COMP_WORDBREAKS may keep
  # \`--flag=val\` whole. Either way, recover $prev=flag and $cur=value.
  if [[ "$cur" == "=" ]]; then
    cur=""
  elif [[ "$prev" == "=" ]]; then
    prev="\${COMP_WORDS[COMP_CWORD-2]}"
  elif [[ "$cur" == --*=* ]]; then
    prev="\${cur%%=*}"
    cur="\${cur#*=}"
  fi
  noun="" verb="" POS=0
  for ((i = 1; i < COMP_CWORD; i++)); do
    w="\${COMP_WORDS[i]}"
    case "$w" in
      --format|--detail) ((i++)) ;;
      -*) ;;
      *)
        if [ -z "$noun" ]; then noun="$w"
        elif [ -z "$verb" ]; then verb="$w"
        fi
        ;;
    esac
  done

  # flag values (verb-scoped, then global)
  case "$noun/$verb/$prev" in
    block/get/--view) COMPREPLY=($(compgen -W "anatomy full summary" -- "$cur")); return ;;
    block/get/--out) COMPREPLY=($(compgen -f -- "$cur")); return ;;
    block/get/--note) return ;;
    block/list/--tags) return ;;
  esac
  case "$prev" in
    --format) COMPREPLY=($(compgen -W "plain json" -- "$cur")); return ;;
    --detail) COMPREPLY=($(compgen -W "summary standard detailed" -- "$cur")); return ;;
  esac

  # flag names
  if [[ "$cur" == -* ]]; then
    case "$noun/$verb" in
      block/get) COMPREPLY=($(compgen -W "--view --out --with-meta --note --llm --format --verbose --detail --help" -- "$cur")); return ;;
      block/list) COMPREPLY=($(compgen -W "--tags --llm --format --verbose --detail --help" -- "$cur")); return ;;
      block/remove) COMPREPLY=($(compgen -W "--dry-run --undo --yes --llm --format --verbose --detail --help" -- "$cur")); return ;;
    esac
    if [ -z "$noun" ]; then
      COMPREPLY=($(compgen -W "--llm --format --verbose --detail --help --version" -- "$cur"))
    else
      COMPREPLY=($(compgen -W "--llm --format --verbose --detail --help" -- "$cur"))
    fi
    return
  fi

  # nouns
  if [ -z "$noun" ]; then
    COMPREPLY=($(compgen -W "block mcp standard status" -- "$cur"))
    return
  fi

  # verbs
  if [ -z "$verb" ]; then
    case "$noun" in
      block) COMPREPLY=($(compgen -W "diff get list remove" -- "$cur")); return ;;
      standard) COMPREPLY=($(compgen -W "list" -- "$cur")); return ;;
    esac
  fi

  # positionals
  case "$noun/$verb" in
    block/diff)
      _pragma_pos 2 "--format --detail"
      case "$POS" in
        *) _pragma_dynamic ;;
      esac
      ;;
    block/get)
      _pragma_pos 2 "--view --out --note --format --detail"
      case "$POS" in
        0) _pragma_dynamic ;;
      esac
      ;;
    block/list)
      _pragma_pos 2 "--tags --format --detail"
      case "$POS" in
        0) COMPREPLY=($(compgen -W "community core" -- "$cur")) ;;
      esac
      ;;
    standard/)
      _pragma_pos 1 "--format --detail"
      case "$POS" in
        0) _pragma_dynamic ;;
      esac
      ;;
    status/)
      _pragma_pos 1 "--format --detail"
      case "$POS" in
        0) COMPREPLY=($(compgen -W "all dirty" -- "$cur")) ;;
      esac
      ;;
  esac
}
complete -F _pragma pragma
"
`;

exports[`emitScripts — snapshots (fixture model) > renders the fish script 1`] = `
"# pragma fish completion (static tier) — generated by \`pragma setup completions\`. Do not edit.
# Structure (nouns, verbs, flags, enum values) is inlined and never execs;
# name arguments call \`pragma __complete\` (storeless, never-throw) once
# 2 chars are typed; file arguments use native completion (-rF). Requires fish >= 3.
function __pragma_words
    set -l toks (commandline -opc)
    set -l cur (commandline -ct)
    printf '%s\\n' $toks[2..-1] $cur
end
function __pragma_minchars
    test (string length -- (commandline -ct)) -ge $argv[1]
end
function __pragma_at
    set -l cmd (commandline -opc)
    set -l noun ''
    set -l verb ''
    set -l skip 0
    for w in $cmd[2..-1]
        if test $skip -eq 1
            set skip 0
            continue
        end
        switch $w
            case --format --detail
                set skip 1
            case '-*'
            case '*'
                if test -z "$noun"
                    set noun $w
                else if test -z "$verb"
                    set verb $w
                end
        end
    end
    test "$noun" = "$argv[1]"; and test "$verb" = "$argv[2]"
end
complete -c pragma -f

# nouns
complete -c pragma -n "__pragma_at ''" -a "block mcp standard status"

# global flags
complete -c pragma -l llm
complete -c pragma -l format -x -a "plain json"
complete -c pragma -l verbose
complete -c pragma -l detail -x -a "summary standard detailed"
complete -c pragma -l help
complete -c pragma -n "__pragma_at ''" -l version

# block verbs
complete -c pragma -n "__pragma_at block" -a "diff get list remove"

# standard verbs
complete -c pragma -n "__pragma_at standard" -a "list"

# block/diff
complete -c pragma -n "__pragma_at block diff; and __pragma_minchars 2" -a "(pragma __complete -- (__pragma_words) 2>/dev/null)"

# block/get
complete -c pragma -n "__pragma_at block get" -l view -x -a "anatomy full summary"
complete -c pragma -n "__pragma_at block get" -l out -rF
complete -c pragma -n "__pragma_at block get" -l with-meta
complete -c pragma -n "__pragma_at block get" -l note -x
complete -c pragma -n "__pragma_at block get; and __pragma_minchars 2" -a "(pragma __complete -- (__pragma_words) 2>/dev/null)"

# block/list
complete -c pragma -n "__pragma_at block list" -l tags -x
complete -c pragma -n "__pragma_at block list" -a "community core"

# block/remove
complete -c pragma -n "__pragma_at block remove" -l dry-run
complete -c pragma -n "__pragma_at block remove" -l undo
complete -c pragma -n "__pragma_at block remove" -l yes

# status/
complete -c pragma -n "__pragma_at status" -a "all dirty"
"
`;

exports[`emitScripts — snapshots (fixture model) > renders the zsh script 1`] = `
"#compdef pragma
# pragma zsh completion (static tier) — generated by \`pragma setup completions\`. Do not edit.
# Structure (nouns, verbs, flags, enum values) is inlined and never execs;
# entity arguments call \`pragma __complete\` (storeless, never-throw);
# file arguments use _files. Requires zsh >= 5.
_pragma_dynamic() {
  (( \${#cur} >= 2 )) || return 0
  local -a _matches
  _matches=("\${(f)$(pragma __complete -- "\${(@)words[2,CURRENT]}" 2>/dev/null)}")
  (( \${#_matches[@]} == 1 )) && [[ -z "\${_matches[1]}" ]] && return 0
  compadd -- "\${_matches[@]}"
}
_pragma_pos() {
  local skip="$1" vflags=" $2 " w
  local -i i
  POS=0
  for ((i = 2; i < CURRENT; i++)); do
    w="\${words[i]}"
    case "$w" in
      -*) [[ "$vflags" == *" $w "* ]] && ((i++)) ;;
      *) if (( skip > 0 )); then (( skip-- )); else (( POS++ )); fi ;;
    esac
  done
}
_pragma() {
  local cur prev noun verb w
  local -i i POS
  cur="\${words[CURRENT]}"
  prev="\${words[CURRENT-1]}"
  # Split an inline --flag=value word so the value routes as a flag value
  # (mirrors parse.ts). zsh keeps \`--flag=value\` as one word, so recover
  # $prev=flag and $cur=value before the flag-value cases below.
  if [[ "$cur" == --*=* ]]; then
    prev="\${cur%%=*}"
    cur="\${cur#*=}"
  fi
  noun="" verb="" POS=0
  for ((i = 2; i < CURRENT; i++)); do
    w="\${words[i]}"
    case "$w" in
      --format|--detail) ((i++)) ;;
      -*) ;;
      *)
        if [[ -z "$noun" ]]; then noun="$w"
        elif [[ -z "$verb" ]]; then verb="$w"
        fi
        ;;
    esac
  done

  # flag values (verb-scoped, then global)
  case "$noun/$verb/$prev" in
    block/get/--view) compadd -- anatomy full summary; return 0 ;;
    block/get/--out) _files; return 0 ;;
    block/get/--note) return 0 ;;
    block/list/--tags) return 0 ;;
  esac
  case "$prev" in
    --format) compadd -- plain json; return 0 ;;
    --detail) compadd -- summary standard detailed; return 0 ;;
  esac

  # flag names
  if [[ "$cur" == -* ]]; then
    case "$noun/$verb" in
      block/get) compadd -- --view --out --with-meta --note --llm --format --verbose --detail --help; return 0 ;;
      block/list) compadd -- --tags --llm --format --verbose --detail --help; return 0 ;;
      block/remove) compadd -- --dry-run --undo --yes --llm --format --verbose --detail --help; return 0 ;;
    esac
    if [[ -z "$noun" ]]; then
      compadd -- --llm --format --verbose --detail --help --version
    else
      compadd -- --llm --format --verbose --detail --help
    fi
    return 0
  fi

  # nouns
  if [[ -z "$noun" ]]; then
    compadd -- block mcp standard status
    return 0
  fi

  # verbs
  if [[ -z "$verb" ]]; then
    case "$noun" in
      block) compadd -- diff get list remove; return 0 ;;
      standard) compadd -- list; return 0 ;;
    esac
  fi

  # positionals
  case "$noun/$verb" in
    block/diff)
      _pragma_pos 2 "--format --detail"
      case "$POS" in
        *) _pragma_dynamic ;;
      esac
      ;;
    block/get)
      _pragma_pos 2 "--view --out --note --format --detail"
      case "$POS" in
        0) _pragma_dynamic ;;
      esac
      ;;
    block/list)
      _pragma_pos 2 "--tags --format --detail"
      case "$POS" in
        0) compadd -- community core ;;
      esac
      ;;
    standard/)
      _pragma_pos 1 "--format --detail"
      case "$POS" in
        0) _pragma_dynamic ;;
      esac
      ;;
    status/)
      _pragma_pos 1 "--format --detail"
      case "$POS" in
        0) compadd -- all dirty ;;
      esac
      ;;
  esac
}
_pragma "$@"
"
`;
