# App — root React Ink component for the summon CLI generator flow.
# Renders a padded vertical container with a header (generator name + version),
# a description line, then one state-conditional content block driven by the
# AppState phase: loading (spinner), prompting (PromptSequence), preview
# (dry-run timeline), confirming (answers table + effects summary / file
# contents + confirm prompt), executing (ExecutionProgress), complete
# (success + effect timeline + summary), or error (message + code + arguments).
# Each phase block is a mutually-exclusive conditional child (0..1).

@prefix ds: <https://ds.canonical.com/>.

ds:cli.component.app a ds:Component;
    ds:name "App";
    ds:summary "Root React Ink component for the summon CLI. Renders a padded column with a generator header and description, then one of seven mutually-exclusive phase blocks (loading, prompting, preview, confirming, executing, complete, error) driving the whole generate/preview/confirm/execute flow.";
    ds:tier ds:cli;
    ds:anatomyDsl "uri: cli.component.app\nstyles:\n  layout.type: stack\n  layout.direction: column\n  spacing.padding: 1\nedges:\n  - node:\n      role: header\n      styles:\n        layout.type: flow\n        layout.direction: row\n        spacing.marginBottom: 1\n      edges:\n        - node:\n            role: generator-name\n            styles:\n              appearance.bold: true\n              appearance.color: magenta\n          relation:\n            cardinality: \"1\"\n        - node:\n            role: generator-version\n            styles:\n              appearance.dim: true\n          relation:\n            cardinality: \"1\"\n    relation:\n      cardinality: \"1\"\n  - node:\n      role: description\n      styles:\n        appearance.dim: true\n    relation:\n      cardinality: \"1\"\n  - node:\n      role: loading-content\n      edges:\n        - node:\n            role: spinner\n          relation:\n            cardinality: \"1\"\n            slotName: Spinner\n    relation:\n      cardinality: \"0..1\"\n      slotName: phase-loading\n  - node:\n      role: prompting-content\n      edges:\n        - node:\n            role: prompt-sequence\n          relation:\n            cardinality: \"1\"\n            slotName: PromptSequence\n    relation:\n      cardinality: \"0..1\"\n      slotName: phase-prompting\n  - node:\n      role: preview-content\n      styles:\n        layout.type: stack\n        layout.direction: column\n      edges:\n        - node:\n            role: dry-run-timeline\n          relation:\n            cardinality: \"1\"\n            slotName: DryRunTimeline\n        - node:\n            role: dry-run-note\n            styles:\n              spacing.marginTop: 1\n              appearance.dim: true\n          relation:\n            cardinality: \"1\"\n    relation:\n      cardinality: \"0..1\"\n      slotName: phase-preview\n  - node:\n      role: confirming-content\n      styles:\n        layout.type: stack\n        layout.direction: column\n      edges:\n        - node:\n            role: completed-answers-table\n          relation:\n            cardinality: \"1\"\n            slotName: CompletedAnswersTable\n        - node:\n            role: file-content-view\n          relation:\n            cardinality: \"0..1\"\n            slotName: FileContentView\n        - node:\n            role: effects-summary-table\n          relation:\n            cardinality: \"0..1\"\n            slotName: EffectsSummaryTable\n        - node:\n            role: confirm-prompt\n            styles:\n              layout.type: flow\n              layout.direction: row\n            edges:\n              - node:\n                  role: prompt-caret\n                  styles:\n                    appearance.color: magenta\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: prompt-label\n                  styles:\n                    appearance.bold: true\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: prompt-choices-hint\n                  styles:\n                    appearance.dim: true\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: prompt-keys-hint\n                  styles:\n                    appearance.dim: true\n                    appearance.italic: true\n                relation:\n                  cardinality: \"1\"\n          relation:\n            cardinality: \"1\"\n    relation:\n      cardinality: \"0..1\"\n      slotName: phase-confirming\n  - node:\n      role: executing-content\n      edges:\n        - node:\n            role: execution-progress\n          relation:\n            cardinality: \"1\"\n            slotName: ExecutionProgress\n    relation:\n      cardinality: \"0..1\"\n      slotName: phase-executing\n  - node:\n      role: complete-content\n      styles:\n        layout.type: stack\n        layout.direction: column\n      edges:\n        - node:\n            role: success-message\n            styles:\n              appearance.color: green\n          relation:\n            cardinality: \"1\"\n        - node:\n            role: effect-timeline\n          relation:\n            cardinality: \"1\"\n            slotName: EffectTimeline\n        - node:\n            role: summary-line\n            styles:\n              spacing.marginTop: 1\n              appearance.dim: true\n          relation:\n            cardinality: \"1\"\n    relation:\n      cardinality: \"0..1\"\n      slotName: phase-complete\n  - node:\n      role: error-content\n      styles:\n        layout.type: stack\n        layout.direction: column\n      edges:\n        - node:\n            role: error-message\n            styles:\n              appearance.color: red\n          relation:\n            cardinality: \"1\"\n        - node:\n            role: error-code\n            styles:\n              spacing.marginTop: 1\n              appearance.dim: true\n          relation:\n            cardinality: \"0..1\"\n        - node:\n            role: error-arguments\n            styles:\n              layout.type: stack\n              layout.direction: column\n              spacing.marginTop: 1\n            edges:\n              - node:\n                  role: arguments-title\n                  styles:\n                    appearance.dim: true\n                    appearance.bold: true\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: argument-row\n                  styles:\n                    spacing.indent: 1\n                    appearance.dim: true\n                relation:\n                  cardinality: \"0..n\"\n          relation:\n            cardinality: \"0..1\"\n    relation:\n      cardinality: \"0..1\"\n      slotName: phase-error\n".
