# PromptSequence — CLI interactive prompt runner (React Ink).
# Renders a vertical stack: a dim progress header (group · step X of Y · esc-to-go-back),
# an optional borderless table of already-answered questions, and exactly one active prompt.
# The active prompt is one of four polymorphic forms (text / confirm / select / multiselect),
# selected on prompt.type; each renders a magenta "›" pointer, a bold message, and its input.

@prefix ds: <https://ds.canonical.com/>.
ds:cli.component.prompt-sequence a ds:Component;
    ds:name "PromptSequence";
    ds:summary "Interactive Ink prompt sequence that walks the user through a list of generator prompts one at a time, showing a progress header, the previously answered questions, and the current polymorphic prompt (text, confirm, select, or multiselect).";
    ds:tier ds:cli;
    ds:anatomyDsl "uri: cli.component.prompt-sequence\nstyles:\n  layout.type: stack\n  layout.direction: column\nedges:\n  - node:\n      role: progress-header\n      styles:\n        layout.type: flow\n        spacing.marginBottom: 1\n        appearance.dim: true\n      edges:\n        - node:\n            role: progress-label\n            styles:\n              appearance.dim: true\n            edges:\n              - node:\n                  role: back-hint\n                  styles:\n                    appearance.dim: true\n                    appearance.italic: true\n                relation:\n                  cardinality: \"1\"\n          relation:\n            cardinality: \"1\"\n    relation:\n      cardinality: \"1\"\n      slotName: header\n  - node:\n      role: completed-answers-table\n      styles:\n        layout.type: stack\n        layout.direction: column\n        spacing.marginBottom: 1\n      edges:\n        - node:\n            role: answer-row\n            styles:\n              layout.type: flow\n              layout.direction: row\n            edges:\n              - node:\n                  role: check-icon\n                  styles:\n                    appearance.color: green\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: answer-question\n                  styles:\n                    appearance.dim: true\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: answer-value\n                  styles:\n                    appearance.color: cyan\n                relation:\n                  cardinality: \"1\"\n          relation:\n            cardinality: \"0..n\"\n    relation:\n      cardinality: \"0..1\"\n      slotName: completed\n  - node:\n      role: current-prompt\n      edges:\n        - node:\n            role: text-prompt\n            styles:\n              layout.type: stack\n              layout.direction: column\n            edges:\n              - node:\n                  role: prompt-header\n                  styles:\n                    layout.type: flow\n                    layout.direction: row\n                  edges:\n                    - node:\n                        role: pointer\n                        styles:\n                          appearance.color: magenta\n                      relation:\n                        cardinality: \"1\"\n                    - node:\n                        role: label\n                        styles:\n                          appearance.bold: true\n                      relation:\n                        cardinality: \"1\"\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: text-input\n                  styles:\n                    spacing.indent: 2\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: error-message\n                  styles:\n                    spacing.indent: 2\n                    appearance.color: red\n                relation:\n                  cardinality: \"0..1\"\n          relation:\n            cardinality: \"0..1\"\n        - node:\n            role: confirm-prompt\n            styles:\n              layout.type: flow\n              layout.direction: row\n            edges:\n              - node:\n                  role: pointer\n                  styles:\n                    appearance.color: magenta\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: label\n                  styles:\n                    appearance.bold: true\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: default-hint\n                  styles:\n                    appearance.dim: true\n                relation:\n                  cardinality: \"1\"\n          relation:\n            cardinality: \"0..1\"\n        - node:\n            role: select-prompt\n            styles:\n              layout.type: stack\n              layout.direction: column\n            edges:\n              - node:\n                  role: prompt-header\n                  styles:\n                    layout.type: flow\n                    layout.direction: row\n                  edges:\n                    - node:\n                        role: pointer\n                        styles:\n                          appearance.color: magenta\n                      relation:\n                        cardinality: \"1\"\n                    - node:\n                        role: label\n                        styles:\n                          appearance.bold: true\n                      relation:\n                        cardinality: \"1\"\n                    - node:\n                        role: keys-hint\n                        styles:\n                          appearance.dim: true\n                      relation:\n                        cardinality: \"1\"\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: select-input\n                  styles:\n                    spacing.indent: 2\n                relation:\n                  cardinality: \"1\"\n          relation:\n            cardinality: \"0..1\"\n        - node:\n            role: multiselect-prompt\n            styles:\n              layout.type: stack\n              layout.direction: column\n            edges:\n              - node:\n                  role: prompt-header\n                  styles:\n                    layout.type: flow\n                    layout.direction: row\n                  edges:\n                    - node:\n                        role: pointer\n                        styles:\n                          appearance.color: magenta\n                      relation:\n                        cardinality: \"1\"\n                    - node:\n                        role: label\n                        styles:\n                          appearance.bold: true\n                      relation:\n                        cardinality: \"1\"\n                    - node:\n                        role: keys-hint\n                        styles:\n                          appearance.dim: true\n                      relation:\n                        cardinality: \"1\"\n                relation:\n                  cardinality: \"1\"\n              - node:\n                  role: choice-list\n                  styles:\n                    layout.type: stack\n                    layout.direction: column\n                    spacing.indent: 2\n                  edges:\n                    - node:\n                        role: choice-row\n                        styles:\n                          layout.type: flow\n                          layout.direction: row\n                        edges:\n                          - node:\n                              role: choice-pointer\n                              styles:\n                                appearance.color: magenta\n                            relation:\n                              cardinality: \"1\"\n                          - node:\n                              role: choice-checkbox\n                              styles:\n                                appearance.color: green\n                            relation:\n                              cardinality: \"1\"\n                          - node:\n                              role: choice-label\n                            relation:\n                              cardinality: \"1\"\n                      relation:\n                        cardinality: \"0..n\"\n                relation:\n                  cardinality: \"1\"\n          relation:\n            cardinality: \"0..1\"\n    relation:\n      cardinality: \"1\"\n      slotName: current".
