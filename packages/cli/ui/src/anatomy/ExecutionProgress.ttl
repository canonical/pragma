# ExecutionProgress — CLI (React Ink) component.
# Renders live task-execution feedback effect-by-effect: a vertical column
# containing a running list of log messages, a running list of completed
# file effects (each with a green check and a dimmed duration), an active
# spinner + label for the effect currently in flight, and an idle
# "Executing..." spinner while the task runs with no active effect.
# Structure below mirrors the actual JSX: the root Box (flexDirection=column),
# two .map() lists (0..n), and two conditionally-rendered spinner rows (0..1).

@prefix ds: <https://ds.canonical.com/>.
ds:cli.component.execution-progress a ds:Component;
    ds:name "ExecutionProgress";
    ds:summary "A React Ink component that displays the progress of task execution with effect-by-effect feedback: log messages, completed file effects with durations, and a live spinner for the in-flight effect.";
    ds:tier ds:cli;
    ds:anatomyDsl "node:\n  uri: cli.component.execution-progress\n  styles:\n    layout.type: stack\n    layout.direction: column\n  edges:\n    - node:\n        role: log-row\n        styles:\n          layout.type: flow\n          layout.direction: row\n        edges:\n          - node:\n              role: log-icon\n              styles:\n                appearance.color: level\n            relation:\n              cardinality: \"1\"\n          - node:\n              role: log-message\n            relation:\n              cardinality: \"1\"\n      relation:\n        cardinality: \"0..n\"\n        slotName: logMessages\n    - node:\n        role: effect-row\n        styles:\n          layout.type: flow\n          layout.direction: row\n        edges:\n          - node:\n              role: status-icon\n              styles:\n                appearance.color: green\n            relation:\n              cardinality: \"1\"\n          - node:\n              role: effect-label\n            relation:\n              cardinality: \"1\"\n          - node:\n              role: effect-duration\n              styles:\n                appearance.dim: true\n            relation:\n              cardinality: \"1\"\n      relation:\n        cardinality: \"0..n\"\n        slotName: completedEffects\n    - node:\n        role: current-effect-row\n        styles:\n          layout.type: flow\n          layout.direction: row\n        edges:\n          - node:\n              role: spinner\n              styles:\n                appearance.color: blue\n            relation:\n              cardinality: \"1\"\n          - node:\n              role: effect-label\n            relation:\n              cardinality: \"1\"\n      relation:\n        cardinality: \"0..1\"\n        slotName: currentEffect\n    - node:\n        role: running-indicator-row\n        styles:\n          layout.type: flow\n          layout.direction: row\n        edges:\n          - node:\n              role: spinner\n              styles:\n                appearance.color: blue\n              edges:\n                - node:\n                    role: spinner-label\n                  relation:\n                    cardinality: \"1\"\n            relation:\n              cardinality: \"1\"\n      relation:\n        cardinality: \"0..1\"\n        slotName: running".
