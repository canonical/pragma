{
  "extends": "@canonical/typescript-config-svelte",
  "compilerOptions": {
    "skipLibCheck": true,
    "moduleResolution": "nodenext"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "src/**/*.d.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.svelte",
    "testing/**/*.ts"
  ]
}
