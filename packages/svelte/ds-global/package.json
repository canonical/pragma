{
  "name": "@canonical/svelte-ds-global",
  "description": "Global components for the Pragma design system.",
  "version": "0.29.0-experimental.0",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "svelte": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.stories.*",
    "!dist/**/*.mdx"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canonical/pragma.git"
  },
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma/tree/main/packages/svelte/ds-global#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:all": "bun run build",
    "build": "svelte-package -o dist -i src/lib --tsconfig ./tsconfig.build.json",
    "build:storybook": "storybook build",
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "svelte-check --tsconfig ./tsconfig.json",
    "check:webarchitect": "webarchitect package-svelte -v",
    "test": "bun run test:vitest",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "storybook": "storybook dev -p 6006 --no-open --host 0.0.0.0"
  },
  "dependencies": {
    "@canonical/ds-assets": "^0.29.0-experimental.0",
    "@canonical/styles": "^0.28.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^0.28.0",
    "@canonical/design-tokens": "^0.6.0",
    "@canonical/ds-types": "^0.29.0-experimental.0",
    "@canonical/storybook-config": "^0.29.0-experimental.0",
    "@canonical/storybook-helpers": "^0.29.0-experimental.0",
    "@canonical/svelte-ssr-test": "^0.28.0",
    "@canonical/typescript-config-svelte": "^0.29.0",
    "@canonical/webarchitect": "^0.29.0-experimental.0",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.8",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "jsdom": "^28.1.0",
    "storybook": "^10.3.1",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "svelte": "^5.47.1"
  }
}
