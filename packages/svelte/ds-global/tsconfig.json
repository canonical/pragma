{
  "extends": "@canonical/typescript-config-svelte",
  "compilerOptions": {
    "skipLibCheck": true,
    "moduleResolution": "nodenext"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    ".storybook/**/*.ts",
    ".storybook/**/*.svelte",
    "vite.config.ts",
    "vitest.setup.ts"
  ],
  "types": [
    "node",
    "svelte",
    "vitest/globals",
    "vite/client",
    "@testing-library/jest-dom"
  ]
}
