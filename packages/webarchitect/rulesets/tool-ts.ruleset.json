{
  "$schema": "https://raw.githubusercontent.com/canonical/pragma/refs/heads/main/packages/webarchitect/src/schema.json",
  "name": "tool-ts",
  "extends": ["base"],
  "variables": {
    "prefix": {
      "default": "@canonical/",
      "schema": { "type": "string" }
    }
  },
  "biome": {
    "file": {
      "name": "biome.json",
      "contains": {
        "type": "object",
        "properties": {
          "$schema": {
            "type": "string"
          },
          "extends": {
            "type": "array",
            "items": { "const": "@canonical/biome-config" },
            "minItems": 1,
            "maxItems": 1
          },
          "files": {
            "type": "object",
            "properties": {
              "includes": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false,
            "description": "File inclusion patterns only"
          }
        },
        "required": ["extends"],
        "additionalProperties": false
      }
    }
  },
  "package-structure": {
    "file": {
      "name": "package.json",
      "contains": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^${prefix}"
          },
          "version": {
            "type": "string"
          },
          "type": {
            "const": "module"
          },
          "module": {
            "type": "string",
            "pattern": "^dist/",
            "description": "Module entry point must be a compiled dist artifact, never source"
          },
          "types": {
            "type": "string",
            "pattern": "^dist/",
            "description": "Type declarations must be a compiled dist artifact, never source"
          },
          "files": {
            "type": "array",
            "contains": { "const": "dist" }
          },
          "scripts": {
            "type": "object",
            "properties": {
              "build": {
                "type": "string",
                "description": "Build command producing the compiled dist output (implementation flexible)"
              },
              "test": {
                "type": "string",
                "description": "Test command (implementation flexible)"
              },
              "check:ts": {
                "const": "tsc --noEmit"
              }
            },
            "required": ["build", "test", "check:ts"]
          }
        },
        "required": ["name", "version", "type", "files", "scripts"]
      }
    }
  },
  "package-license": {
    "file": {
      "name": "package.json",
      "contains": {
        "type": "object",
        "properties": {
          "license": {
            "const": "GPL-3.0"
          }
        },
        "required": ["license"]
      }
    }
  }
}
