{
  "extends": "@canonical/typescript-config-react",
  "compilerOptions": {
    "baseUrl": "src",
    "skipLibCheck": true,
    "types": ["bun-types", "node", "react", "react-dom", "vitest/globals"],
    "noEmit": true,
    "paths": {
      "#lib/*": ["./lib/*"],
      "#domains/*": ["./domains/*"],
      "#styles/*": ["./styles/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
