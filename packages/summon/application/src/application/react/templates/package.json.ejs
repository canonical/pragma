{
  "name": "<%= name %>",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "GPL-3.0-only",
  "imports": {
    "#lib/*": "./src/lib/*",
    "#domains/*": "./src/domains/*",
<% if (relay) { -%>
    "#relay/*": "./src/relay/*",
<% } -%>
    "#styles/*": "./src/styles/*"
  },
  "scripts": {
    "dev": "vite",
    "dev:express": "node --import tsx src/server/server.express.ts",
    "dev:bun": "bun src/server/server.bun.ts",
    "preview": "bun run build:client && vite preview --outDir dist/client",
    "preview:bun": "bun run build:client && bun run build:server && bun src/server/preview.bun.ts",
    "preview:express": "bun run build:client && bun run build:server && node --import tsx src/server/preview.express.ts",
    "build": "bun run build:client",
    "build:all": "bun run build:client && bun run build:storybook",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "vite build --mode server",
    "build:storybook": "storybook build",
    "check": "bun run check:biome && bun run check:ts",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
<% if (relay) { -%>
    "relay": "relay-compiler",
    "relay:watch": "relay-compiler --watch",
<% } -%>
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "storybook": "storybook dev -p 6010 --no-open --host 0.0.0.0"
  },
  "dependencies": {
    "@canonical/react-ds-global": "<%= pragmaVersion %>",
<% if (forms) { -%>
    "@canonical/react-ds-global-form": "<%= pragmaVersion %>",
<% } -%>
    "@canonical/react-head": "<%= pragmaVersion %>",
    "@canonical/react-hooks": "<%= pragmaVersion %>",
    "@canonical/react-ssr": "<%= pragmaVersion %>",
    "@canonical/router-core": "<%= pragmaVersion %>",
    "@canonical/router-react": "<%= pragmaVersion %>",
<% if (relay) { -%>
    "@canonical/storybook-addon-relay": "<%= pragmaVersion %>",
<% } -%>
    "@canonical/storybook-config": "<%= pragmaVersion %>",
    "@canonical/styles": "<%= pragmaVersion %>",
    "express": "^5.2.1",
<% if (relay) { -%>
    "graphql": "^16.11.0",
<% } -%>
    "react": "^19.2.4",
    "react-dom": "^19.2.4"<% if (relay) { %>,
    "react-relay": "^21.0.1",
    "relay-runtime": "^21.0.1",
    "relay-runtime-network": "^0.1.0"<% } %>
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "<%= pragmaVersion %>",
    "@canonical/typescript-config-react": "<%= pragmaVersion %>",
    "@storybook/react-vite": "^10.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
<% if (relay) { -%>
    "@types/react-relay": "^18.2.1",
    "@types/relay-runtime": "^20.1.1",
    "@types/relay-test-utils": "^19.0.0",
<% } -%>
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "browserslist": "^4.28.1",
    "bun-types": "^1.3.9",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.32.0",
<% if (relay) { -%>
    "relay-compiler": "^21.0.1",
    "relay-test-utils": "^21.0.1",
<% } -%>
    "storybook": "^10.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
<% if (relay) { -%>
    "vite-plugin-relay-lite": "^0.12.0",
<% } -%>
    "vitest": "^4.0.18"
  }<% if (relay && standalone) { %>,
  "patchedDependencies": {
    "react-relay@21.0.1": "patches/react-relay@21.0.1.patch",
    "relay-runtime@21.0.1": "patches/relay-runtime@21.0.1.patch",
    "relay-runtime-network@0.1.0": "patches/relay-runtime-network@0.1.0.patch"
  }<% } %>
}
