{
  "name": "@canonical/summon-application",
  "description": "Summon generators for application scaffolding: domain, route, and wrapper",
  "version": "0.25.0",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "GPL-3.0",
  "scripts": {
    "build": "echo 'No build needed - runs directly from TypeScript'",
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:webarchitect": "webarchitect tool-ts",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@canonical/summon-core": "^0.25.0",
    "@canonical/task": "^0.25.0",
    "@canonical/utils": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^0.25.0",
    "@canonical/webarchitect": "^0.25.0",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
