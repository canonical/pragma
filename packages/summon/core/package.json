{
  "name": "@canonical/summon-core",
  "description": "Code generation framework: generator definitions, templates, stamps, discovery. Built on @canonical/task.",
  "version": "0.22.0",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "imports": {
    "#types": "./src/types/index.ts",
    "#stamp": "./src/stamp/index.ts",
    "#template": "./src/template/index.ts",
    "#discovery": "./src/discovery/index.ts"
  },
  "files": [
    "src"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "scripts": {
    "build": "echo 'No build needed - runs directly from TypeScript'",
    "build:all": "bun run build",
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
    "check:webarchitect": "webarchitect tool-ts",
    "test": "bun run test:vitest",
    "test:vitest": "vitest run --coverage",
    "test:vitest:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^0.22.0",
    "@canonical/typescript-config": "^0.22.0",
    "@canonical/webarchitect": "^0.22.0",
    "@types/bun": "^1.3.10",
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@canonical/task": "^0.22.0",
    "@canonical/utils": "^0.22.0",
    "chalk": "^5.6.2",
    "ejs": "^5.0.0"
  }
}
