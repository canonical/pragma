{
  "name": "<%= name %>",
  "description": "<%= description %>",
  "version": "<%= version %>",
  "type": "module",
  "module": "<%= module %>",
<% if (types) { -%>
  "types": "<%= types %>",
<% } -%>
<% if (type === 'library') { -%>
  "exports": {
    ".": {
      "types": "./<%= types %>",
      "import": "./<%= module %>"
    }
  },
<% } -%>
<% if (withCli && type !== 'css') { -%>
  "bin": {
    "<%= shortName %>": "src/cli.ts"
  },
<% } -%>
  "files": [
<% files.forEach((file, index) => { -%>
    "<%= file %>"<%= index < files.length - 1 ? "," : "" %>
<% }) -%>
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "<%= license %>",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
<% if (type === 'tool-ts' || type === 'css') { -%>
    "build": "echo 'No build needed'",
<% } else { -%>
    "build": "tsc -p tsconfig.build.json",
<% } -%>
<% if (withStorybook) { -%>
    "build:all": "bun run build && bun run build:storybook",
    "build:storybook": "storybook build",
<% } else { -%>
    "build:all": "bun run build",
<% } -%>
<% if (type === 'css') { -%>
    "check": "bun run check:biome && bun run check:webarchitect",
    "check:fix": "bun run check:biome:fix",
<% } else { -%>
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
<% } -%>
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
<% if (type !== 'css') { -%>
    "check:ts": "tsc --noEmit",
<% } -%>
    "check:webarchitect": "webarchitect <%= ruleset %>",
<% if (withStorybook) { -%>
    "storybook": "storybook dev -p 6006 --no-open --host 0.0.0.0",
<% } -%>
<% if (type === 'css') { -%>
    "test": "echo 'No tests for CSS package'"
<% } else { -%>
    "test": "vitest run",
    "test:watch": "vitest"
<% } -%>
  },
<% if (framework === 'react') { -%>
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
<% } -%>
<% if (type === 'css') { -%>
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^<%= configsVersion %>",
    "@canonical/webarchitect": "^<%= configsVersion %>"
  }
<% } else if (framework === 'react') { -%>
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^<%= configsVersion %>",
    "@canonical/typescript-config-react": "^<%= configsVersion %>",
    "@canonical/vitest-config-react": "^<%= configsVersion %>",
    "@canonical/webarchitect": "^<%= configsVersion %>",
<% if (withStorybook) { -%>
    "@canonical/storybook-config": "^<%= configsVersion %>",
<% } -%>
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^28.1.0",
<% if (withStorybook) { -%>
    "storybook": "^10.3.1",
<% } -%>
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.0.18"
  }
<% } else { -%>
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^<%= configsVersion %>",
    "@canonical/typescript-config": "^<%= configsVersion %>",
    "@canonical/webarchitect": "^<%= configsVersion %>",
<% if (withStorybook) { -%>
    "@canonical/storybook-config": "^<%= configsVersion %>",
<% } -%>
<% if (type === 'tool-ts') { -%>
    "@types/bun": "^1.3.10",
<% } -%>
    "@types/node": "^24.12.0",
<% if (withStorybook) { -%>
    "storybook": "^10.3.1",
<% } -%>
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
<% } -%>
}
