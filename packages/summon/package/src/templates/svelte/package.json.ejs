{
  "name": "<%= name %>",
  "description": "<%= description %>",
  "version": "<%= version %>",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "svelte": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.stories.*"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "svelte-package -o dist -i src/lib --tsconfig ./tsconfig.build.json",
    "build:all": "bun run build",
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "svelte-check --tsconfig ./tsconfig.json",
    "check:webarchitect": "webarchitect package-svelte",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:server": "vitest --run --project=server",
    "test:ssr": "vitest --run --project=ssr",
    "test:client": "vitest --run --project=client",
    "test:client:chromium": "vitest --run --project=client --browser=chromium",
    "test:client:firefox": "vitest --run --project=client --browser=firefox",
    "test:client:webkit": "vitest --run --project=client --browser=webkit",
    "test:watch:client": "bun run test:watch --project=client --browser.headless=false"<% if (withStorybook) { %>,
    "storybook": "storybook dev -p 6006 --no-open --host 0.0.0.0",
    "build:storybook": "storybook build"<% } %>
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^<%= configsVersion %>",
    "@canonical/svelte-ssr-test": "^<%= configsVersion %>",
    "@canonical/typescript-config-svelte": "^<%= configsVersion %>",
    "@canonical/webarchitect": "^<%= configsVersion %>",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "playwright": "^1.61.1",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.0.18",
    "vitest-browser-svelte": "^2.0.2"<% if (withStorybook) { %>,
    "@canonical/storybook-config": "^<%= configsVersion %>",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "storybook": "^10.3.1"<% } %>
  },
  "peerDependencies": {
    "svelte": "^5.47.1"
  },
  "nx": {
    "tags": [
      "playwright"
    ]
  }
}
