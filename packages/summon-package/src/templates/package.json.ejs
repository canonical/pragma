{
  "name": "<%= name %>",
  "description": "<%= description %>",
  "version": "<%= version %>",
  "type": "module",
<% if (type === 'tool-ts') { -%>
  "module": "src/index.ts",
  "types": "src/index.ts",
<% } else if (type === 'css') { -%>
  "module": "src/index.css",
<% } else { -%>
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
<% } -%>
<% if (withCli) { -%>
  "bin": {
    "<%= shortName %>": "src/cli.ts"
  },
<% } -%>
  "files": [
<% if (type === 'tool-ts' || type === 'css') { -%>
    "src"
<% } else { -%>
    "dist"
<% } -%>
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "<%= license %>",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "scripts": {
<% if (type === 'tool-ts' || type === 'css') { -%>
    "build": "echo 'No build needed'",
<% } else { -%>
    "build": "bun run build:package",
    "build:package": "bun run build:package:tsc && bun run build:package:copycss",
    "build:package:tsc": "tsc -p tsconfig.build.json",
    "build:package:copycss": "copyfiles -u 1 'src/lib/{,**/}*.css' dist/esm",
<% } -%>
<% if (withStorybook) { -%>
    "build:all": "bun run build && bun run build:storybook",
    "build:storybook": "storybook build",
<% } else { -%>
    "build:all": "bun run build",
<% } -%>
<% if (type === 'css') { -%>
    "check": "bun run check:biome && bun run check:webarchitect",
    "check:fix": "bun run check:biome:fix",
<% } else { -%>
    "check": "bun run check:biome && bun run check:ts && bun run check:webarchitect",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
<% } -%>
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
<% if (type !== 'css') { -%>
    "check:ts": "tsc --noEmit",
<% } -%>
    "check:webarchitect": "webarchitect <%= ruleset %>",
<% if (withStorybook) { -%>
    "storybook": "storybook dev -p 6006 --no-open --host 0.0.0.0",
<% } -%>
<% if (type === 'css') { -%>
    "test": "echo 'No tests for CSS package'"
<% } else { -%>
    "test": "vitest run"
<% } -%>
  },
  "devDependencies": {
<%- Object.entries(devDependencies).map(([pkg, ver], i, arr) =>
  `    "${pkg}": "${ver}"${i < arr.length - 1 ? ',' : ''}`
).join('\n') %>
  }<%= peerDependencies ? ',' : '' %>
<% if (peerDependencies) { -%>
  "peerDependencies": {
<%- Object.entries(peerDependencies).map(([pkg, ver], i, arr) =>
  `    "${pkg}": "${ver}"${i < arr.length - 1 ? ',' : ''}`
).join('\n') %>
  }
<% } -%>
}
