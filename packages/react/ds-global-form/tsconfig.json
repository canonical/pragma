{
  "extends": "@canonical/typescript-config-react",
  "compilerOptions": {
    "baseUrl": "src",
    "skipLibCheck": true,
    // Resolve the `#lib/*` self-imports against `src` during type-checking
    // (matches the package `imports` `development` condition). At runtime the
    // published package resolves `#lib/*` via `default` -> `./dist/esm/lib/*`.
    "customConditions": ["development"],
    "types": [
      "node",
      "react",
      "react-dom",
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".storybook/*.ts",
    ".storybook/*.tsx",
    "vite.config.ts",
    "vitest.setup.ts"
  ]
}
