{
  "extends": "../../../configs/typescript-react/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "src",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "types": [
      "node",
      "react",
      "react-dom",
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".storybook/*.ts",
    ".storybook/*.tsx",
    "vite.config.ts",
    "vitest.setup.ts",
    "vitest.config.ts"
  ]
}
