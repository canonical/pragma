{
  "name": "@canonical/react-ssr",
  "description": "TBD",
  "version": "0.26.0",
  "type": "module",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "author": {
    "email": "webteam@canonical.com",
    "name": "Canonical Webteam"
  },
  "bin": {
    "serve-express": "./dist/esm/bin/serve-express.js",
    "serve-bun": "./dist/esm/bin/serve-bun.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/canonical/pragma"
  },
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/canonical/pragma/issues"
  },
  "homepage": "https://github.com/canonical/pragma#readme",
  "imports": {
    "#adapter": "./src/lib/adapter/index.ts",
    "#renderer": "./src/lib/renderer/index.ts",
    "#server": "./src/lib/server/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:all": "tsc -p tsconfig.build.json",
    "check": "bun run check:biome && bun run check:webarchitect",
    "check:webarchitect": "webarchitect library",
    "check:fix": "bun run check:biome:fix && bun run check:ts",
    "check:biome": "biome check",
    "check:biome:fix": "biome check --write",
    "check:ts": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./renderer": {
      "import": "./dist/esm/lib/renderer/index.js",
      "types": "./dist/types/lib/renderer/index.d.ts"
    },
    "./renderer/constants": {
      "import": "./dist/esm/lib/renderer/constants.js",
      "types": "./dist/types/lib/renderer/constants.d.ts"
    },
    "./server": {
      "import": "./dist/esm/lib/server/index.js",
      "types": "./dist/types/lib/server/index.d.ts"
    },
    "./adapter": {
      "import": "./dist/esm/lib/adapter/index.js",
      "types": "./dist/types/lib/adapter/index.d.ts"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@canonical/biome-config": "^0.26.0",
    "@canonical/typescript-config-react": "^0.26.0",
    "@canonical/webarchitect": "^0.26.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@canonical/utils": "^0.26.0",
    "htmlparser2": "^10.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "peerDependencies": {
    "express": "^5.2.1"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
